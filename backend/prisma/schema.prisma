generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  passwordResetTokens PasswordResetToken[]
  pickEmPicks         PickEmPick[]
  pickEmWeekScores    PickEmWeekScore[]
}

enum Role {
  USER
  ADMIN
}

enum Conference {
  AFC
  NFC
}

enum ClinchFlag {
  x
  y
  z
  STAR
}

model StandingsRow {
  id         String     @id @default(uuid())
  season     Int
  conference Conference
  division   String
  team       String

  w   Int
  l   Int
  t   Int
  pct Float
  pf  Int
  pa  Int
  net Int

  clinched ClinchFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, conference, division, team]) // egy csapat egyszer szerepeljen divízión belül szezononként
  @@index([season, conference])
  @@index([season, conference, division])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id        String   @id @default(uuid())
  season    Int
  week      Int
  gameType  String   @default("REG") // REG / POST (később)
  kickoffAt DateTime

  homeTeam String
  awayTeam String

  // null = még nincs lejátszva
  homeScore Int?
  awayScore Int?

  status String @default("SCHEDULED") // SCHEDULED / FINAL

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  pickEmPicks PickEmPick[]

  @@index([season, week])
  @@index([kickoffAt])
}

model PickEmPick {
  id     String @id @default(uuid())
  userId String
  gameId String
  picked String // pl. "LAR" vagy "DET"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model PickEmWeekScore {
  id     String @id @default(uuid())
  userId String
  season Int
  week   Int

  correct    Int @default(0)
  totalGames Int @default(0)
  points     Int @default(0)

  calculatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season, week])
  @@index([season, week])
}
